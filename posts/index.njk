---
layout: default_layout.njk
title: posts
---
<ul class="posts">
    {%- for post in collections.posts -%}
        <li>
            <div>
                <a href="{{ post.page.url }}">
                    {{ post.data.title }}
                </a>
                <p>published <time datetime="{{ post.data.date | dateISO }}">{{ post.data.date | dateISO }}</time>
                </p>
            </div>
        </li>
    {%- endfor -%}
</ul>